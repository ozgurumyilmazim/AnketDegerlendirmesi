# ============================================================
# Environment Variables — MMPI Test System (PRODUCTION)
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# Secret generation:
#   DB_PASSWORD:  openssl rand -base64 12
#   JWT_SECRET:   openssl rand -base64 48
# ============================================================

# PostgreSQL password for mmpi_user
DB_PASSWORD=mmpi_password

# JWT signing secret (min 32 characters, used by PostgREST + api.login())
JWT_SECRET="change_me_to_a_random_string_at_least_32_chars#!123"

# Optional: PostgREST config file path (if not using env vars directly)
# PGREST_CONFIG=/etc/postgrest/postgrest.conf
