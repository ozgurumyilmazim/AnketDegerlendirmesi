{
  "name": "mmpi-e2e-tests",
  "version": "1.0.0",
  "type": "module",
  "description": "E2E tests for MMPI Test System using Playwright",
  "scripts": {
    "test": "node node_modules/@playwright/test/cli.js test --project=chromium",
    "test:headed": "node node_modules/@playwright/test/cli.js test --headed",
    "test:debug": "node node_modules/@playwright/test/cli.js test --debug",
    "report": "node node_modules/@playwright/test/cli.js show-report reports",
    "server": "node server.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0"
  }
}
